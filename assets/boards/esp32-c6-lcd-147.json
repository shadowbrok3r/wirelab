{
  "id": "esp32-c6-lcd-147",
  "name": "Waveshare ESP32-C6-LCD-1.47",
  "chip": "Esp32C6",
  "description": "Waveshare ESP32-C6 board with an on-board 1.47\" 172x320 ST7789 SPI LCD, a WS2812 RGB LED and a microSD slot. The LCD is hard-wired to the chip (MOSI 6, SCLK 7, CS 14, DC 15, RST 21, BL 22) - drive it from a script with lcd_init(6, 7, 14, 15, 21). WireLab talks to it over the native USB Serial/JTAG port.",
  "width_mm": 26.0,
  "height_mm": 52.0,
  "notes": [
    "On-board 1.47\" ST7789 LCD (172x320) on SPI: MOSI GPIO6, SCLK GPIO7, CS GPIO14, DC GPIO15, RST GPIO21, backlight GPIO22.",
    "On-board WS2812 addressable RGB LED on GPIO8 - drive it with rgb(r, g, b).",
    "microSD/TF slot shares the LCD SPI bus: MOSI GPIO6, MISO GPIO5, SCLK GPIO7, CS GPIO4.",
    "The BOOT button pulls GPIO9 low; RESET pulls the chip EN line.",
    "GPIO0-GPIO3, GPIO18-GPIO20 and GPIO23 are the free pads for your own wiring; ADC1 covers GPIO0-GPIO6."
  ],
  "specs": [
    "32-bit RISC-V single-core @ 160 MHz",
    "Wi-Fi 6 (802.11ax), 2.4 GHz",
    "Bluetooth 5 LE",
    "802.15.4 (Zigbee / Thread)",
    "1.47\" 172x320 ST7789 LCD over SPI",
    "WS2812 addressable RGB LED",
    "microSD / TF card slot",
    "USB-C (native USB Serial/JTAG)"
  ],
  "features": {
    "rgb_led_gpio": 8,
    "reset_button": true,
    "boot_button_gpio": 9
  },
