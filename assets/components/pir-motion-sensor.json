    { "id": "signal", "name": "OUT", "role": "signal" }
  ],
  "visual": {
    "shape": "sensor_module",
    "color": [230, 228, 220],
    "width_mm": 24.0,
    "height_mm": 33.0
  },
  "sim": { "kind": "digital_sensor" },
  "actions": [],
  "events": [
    { "id": "high", "name": "Motion detected" },
    { "id": "low", "name": "Motion ended" },
    { "id": "changed", "name": "Changed" }
  ]
}
