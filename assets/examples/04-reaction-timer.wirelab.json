    "components": {
      "1": {
        "id": 1,
        "def_id": "push-button",
        "pos": [
          55.0,
          34.0
        ],
        "rotation": 0,
        "label": "btn",
        "props": {},
        "state": {
          "kind": "button",
          "pressed": false
        },
        "script": "// Reaction timer! Press to start; when the LED lights, press as\n// fast as you can. Works in the sim (click-hold the button) and on\n// real hardware alike.\n//\n// You are `btn`. `red_led` and `buzzer` are addressed by name.\n// State machine lives on `this`: \"idle\" -> \"armed\" -> \"lit\".\n\nfn on_start() {\n    this.state = \"idle\";\n    red_led.off();\n    log(\"press the button to start a round\");\n}\n\nfn on_press() {\n    switch this.state {\n        \"idle\" => {\n            this.state = \"armed\";\n            // No random numbers in scripts - millis() jitter works fine.\n            this.due = millis() + 800 + millis() % 1800;\n            log(\"get ready...\");\n        }\n        \"lit\" => {\n            let ms = millis() - this.lit_at;\n            log(`reaction: ${ms} ms`);\n            buzzer.beep(120);\n            red_led.off();\n            this.state = \"idle\";\n        }\n        _ => {\n            log(\"too early!\");\n            buzzer.beep(400);\n            red_led.off();\n            this.state = \"idle\";\n        }\n    }\n}\n\n// on_tick drives the delay so `this` stays writable (after() closures\n// can't touch `this`).\nfn on_tick(dt_ms) {\n    if this.state == \"armed\" && millis() >= this.due {\n        this.state = \"lit\";\n        this.lit_at = millis();\n        red_led.on();\n    }\n}\n"
      },
