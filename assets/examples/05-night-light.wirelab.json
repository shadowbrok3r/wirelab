    "components": {
      "1": {
        "id": 1,
        "def_id": "photoresistor-ldr",
        "pos": [
          55.0,
          30.0
        ],
        "rotation": 0,
        "label": "ldr",
        "props": {},
        "state": {
          "kind": "fraction",
          "value": 0.5
        },
        "script": "// Auto night-light: the darker the room, the brighter the LED.\n// The LDR + 10k form a divider into GPIO1 (ADC); drag the LDR's\n// \"light level\" slider in the inspector to try it in the sim.\n//\n// You are `ldr`; readings arrive in on_reading as millivolts.\n\nfn on_start() {\n    this.lo = 4000;\n    this.hi = 0;\n    log(\"cover or uncover the LDR (slider in the sim)\");\n}\n\nfn on_reading(mv) {\n    // Self-calibrating: track the range we have actually seen.\n    if mv < this.lo { this.lo = mv; }\n    if mv > this.hi { this.hi = mv; }\n    if this.hi - this.lo < 200 { return; }     // not enough range yet\n\n    let dark = (this.hi - mv) * 100 / (this.hi - this.lo);\n    if dark > 15 {\n        red_led.dim(dark);                     // 0..100 percent\n    } else {\n        red_led.off();\n    }\n}\n"
      },
