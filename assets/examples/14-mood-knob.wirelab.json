    "state": {
     "kind": "fraction",
     "value": 0.5
    },
    "script": "// Mood knob: one potentiometer drives both the on-board RGB LED (its\n// color) and a PWM-dimmed lamp LED (its brightness). Turn the knob by\n// dragging its slider in the sim; readings arrive in on_reading as\n// millivolts, 0..3300.\n//\n// You are `knob`; `lamp` is the blue LED wired beside you.\n\nfn on_start() {\n    log(\"turn the knob to set brightness + color\");\n}\n\nfn on_reading(mv) {\n    let pct = mv * 100 / 3300;          // 0..100 percent\n    lamp.dim(pct);                      // PWM brightness on the lamp LED\n\n    // Sweep the on-board RGB from green (low) through amber to red (high).\n    let r = mv * 255 / 3300;\n    let g = (3300 - mv) * 255 / 3300;\n    rgb(r, g, 0);\n}\n"
   },
