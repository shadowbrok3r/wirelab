  ],
  "components": {
   "1": {
    "id": 1,
    "def_id": "touch-sensor-ttp223",
    "pos": [
     45,
     40
    ],
    "rotation": 0,
    "label": "touch",
    "props": {},
    "state": {
     "kind": "toggle",
     "on": false
    },
    "script": "// Touch lamp: tap the TTP223 pad to toggle a relay (the \"lamp\") and a\n// status LED. The toggle switch is a master enable -- taps do nothing\n// while it is off. A tap arrives as on_change(true) in the sim (use the\n// sensor's toggle in the inspector).\n//\n// You are `touch`; `lamp_relay`, `indicator` and `enable` are wired near.\n\nfn on_start() {\n    this.on = false;\n    indicator.off();\n    lamp_relay.off();\n    log(\"tap to toggle the lamp (flip `enable` on first)\");\n}\n\nfn on_change(active) {\n    if !active { return; }              // act on the touch, not the release\n    if !enable.is_on() {\n        log(\"disabled -- flip the enable switch\");\n        return;\n    }\n    this.on = !this.on;\n    if this.on {\n        lamp_relay.on();\n        indicator.on();\n        log(\"lamp ON\");\n    } else {\n        lamp_relay.off();\n        indicator.off();\n        log(\"lamp OFF\");\n    }\n}\n"
   },
   "2": {
    "id": 2,
    "def_id": "relay-module-1ch",
