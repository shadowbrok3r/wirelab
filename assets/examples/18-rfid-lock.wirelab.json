   "1": {
    "id": 1,
    "def_id": "rfid-rc522",
    "pos": [
     45,
     55
    ],
    "rotation": 0,
    "label": "reader",
    "props": {},
    "state": {
     "kind": "none"
    },
    "script": "// RFID door lock (SPI). The RC522 talks over SPI2; we bring the bus up in\n// on_start and poll it. The SIMULATOR has no card, so tap the on-board\n// BOOT button to fake a scan -- even scans read as the authorized card,\n// odd scans as a stranger. On a real board an RC522 sits on sck 6,\n// mosi 7, miso 0, cs 1, rst 23 and the reply lands in on_spi().\n//\n// You are `reader`; `bolt` (servo), `ok_led`, `deny_led`, `beeper`.\n\nfn scan() {\n    spi_xfer(1, [0x02, 0x00, 0x00, 0x00, 0x00]);   // cs=GPIO1, read-UID cmd\n}\n\nfn on_start() {\n    spi_setup(6, 7, 0, 4000);           // sck, mosi, miso, kHz\n    pin(23).output();\n    pin(23).high();                     // hold the RC522 out of reset\n    pin(28).input_pullup();             // BOOT button = fake-scan trigger\n    this.scans = 0;\n    bolt.set_angle(0);                  // deadbolt thrown\n    ok_led.off();\n    deny_led.off();\n    log(\"lock armed -- tap BOOT to simulate a card\");\n}\n\nfn on_pin(gpio, high) {\n    if gpio != 28 || high { return; }   // BOOT is active-low\n    this.scans += 1;\n    scan();\n    if this.scans % 2 == 0 {\n        deny_led.off();\n        ok_led.on();\n        bolt.set_angle(90);             // retract the bolt\n        beeper.beep(80);\n        log(\"access granted\");\n        after(4000, || { ok_led.off(); bolt.set_angle(0); log(\"re-locked\"); });\n    } else {\n        deny_led.on();\n        beeper.beep(300);\n        log(\"access DENIED\");\n        after(1200, || deny_led.off());\n    }\n}\n\nfn on_spi(data) {\n    // On real hardware this holds the bytes the card clocked back.\n    log(`card bytes: ${data.len()}`);\n}\n"
   },
